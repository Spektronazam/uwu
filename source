-- Color ---------------------------------------------------------------
local function createColor(option: any, parent: any, holder: any?)
	option.main = create("TextLabel", {
		LayoutOrder = option.position,
		Size = UDim2.new(1, 0, 0, 31),
		BackgroundTransparency = 1,
		Text = " " .. option.text,
		TextSize = 17,
		Font = Enum.Font.Gotham,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = parent.content,
	})

	table.insert(allOptionRefs, { label = option.main, option = option, parent = parent })

	local colorBoxOutline = create("ImageLabel", {
		Position = UDim2.new(1, -6, 0, 4),
		Size = UDim2.new(-1, 10, 1, -10),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = Color3.fromRGB(100, 100, 100),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent = option.main,
	})

	option.visualize = create("ImageLabel", {
		Position = UDim2.new(0, 2, 0, 2),
		Size = UDim2.new(1, -4, 1, -4),
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = option.color,
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent = colorBoxOutline,
	})

	local inContact = false

	option.main.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			if not option.mainHolder then createColorPickerWindow(option) end
			if library.activePopup then library.activePopup:Close() end
			local pos = option.main.AbsolutePosition
			option.mainHolder.Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 10)
			option.open = true
			option.mainHolder.Visible = true
			library.activePopup = option
			tween(option.mainHolder, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				ImageTransparency = 0,
				Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 4),
			})
			task.delay(0.1, function()
				tween(option.mainHolder, TWEEN_SLOW, { Position = UDim2.new(0, pos.X - 5, 0, pos.Y + 1) })
			end)
			tween(option.satval, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), { BackgroundTransparency = 0 })
			for _, obj in option.mainHolder:GetDescendants() do
				if obj:IsA("TextLabel") then
					tween(obj, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { TextTransparency = 0 })
				elseif obj:IsA("ImageLabel") then
					tween(obj, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { ImageTransparency = 0 })
				elseif obj:IsA("Frame") then
					tween(obj, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { BackgroundTransparency = 0 })
				end
			end
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = true
			if not option.open then
				tween(colorBoxOutline, TWEEN_FAST, { ImageColor3 = Color3.fromRGB(140, 140, 140) })
			end
		end
	end)

	option.main.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = false
			if not option.open then
				tween(colorBoxOutline, TWEEN_FAST, { ImageColor3 = Color3.fromRGB(100, 100, 100) })
			end
		end
	end)

	function option:SetColor(newColor: Color3)
		if self.mainHolder then self:updateVisuals(newColor) end
		self.visualize.ImageColor3 = newColor
		library.flags[self.flag] = newColor
		self.color = newColor
		self.callback(newColor)
	end

	function option:Close()
		library.activePopup = nil
		self.open = false
		local pos = self.main.AbsolutePosition
		tween(self.mainHolder, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			ImageTransparency = 1,
			Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 10),
		})
		tween(self.satval, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), { BackgroundTransparency = 1 })
		for _, obj in self.mainHolder:GetDescendants() do
			if obj:IsA("TextLabel") then
				tween(obj, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { TextTransparency = 1 })
			elseif obj:IsA("ImageLabel") then
				tween(obj, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { ImageTransparency = 1 })
			elseif obj:IsA("Frame") then
				tween(obj, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { BackgroundTransparency = 1 })
			end
		end
		task.delay(0.3, function()
			if not self.open then self.mainHolder.Visible = false end
		end)
	end
end

------------------------------------------------------------------------
-- Load options into a holder
------------------------------------------------------------------------
local function loadOptions(option: any, holder: any?)
	for _, newOption in option.options do
		if     newOption.type == "label"  then createLabel(newOption, option)
		elseif newOption.type == "toggle" then createToggle(newOption, option)
		elseif newOption.type == "button" then createButton(newOption, option)
		elseif newOption.type == "list"   then createList(newOption, option, holder)
		elseif newOption.type == "box"    then createBox(newOption, option)
		elseif newOption.type == "bind"   then createBind(newOption, option)
		elseif newOption.type == "slider" then createSlider(newOption, option)
		elseif newOption.type == "color"  then createColor(newOption, option, holder)
		elseif newOption.type == "folder" then newOption:init()
		end
	end
end

------------------------------------------------------------------------
-- Attach add-option functions to a parent table
------------------------------------------------------------------------
local function attachFunctions(parent: any)

	function parent:AddLabel(option: any): any
		option = if typeof(option) == "table" then option else {}
		option.text     = tostring(option.text)
		option.type     = "label"
		option.position = #self.options
		table.insert(self.options, option)
		return option
	end

	function parent:AddToggle(option: any): any
		option = if typeof(option) == "table" then option else {}
		option.text     = tostring(option.text)
		option.state    = if typeof(option.state) == "boolean" then option.state else false
		option.callback = if typeof(option.callback) == "function" then option.callback else function() end
		option.type     = "toggle"
		option.position = #self.options
		option.flag     = option.flag or option.text
		library.flags[option.flag] = option.state
		table.insert(self.options, option)
		return option
	end

	function parent:AddButton(option: any): any
		option = if typeof(option) == "table" then option else {}
		option.text     = tostring(option.text)
		option.callback = if typeof(option.callback) == "function" then option.callback else function() end
		option.type     = "button"
		option.position = #self.options
		option.flag     = option.flag or option.text
		table.insert(self.options, option)
		return option
	end

	function parent:AddBind(option: any): any
		option = if typeof(option) == "table" then option else {}
		option.text     = tostring(option.text)
		option.key      = (if option.key then (if typeof(option.key) == "EnumItem" then option.key.Name else option.key) else "F")
		option.hold     = if typeof(option.hold) == "boolean" then option.hold else false
		option.callback = if typeof(option.callback) == "function" then option.callback else function() end
		option.type     = "bind"
		option.position = #self.options
		option.flag     = option.flag or option.text
		library.flags[option.flag] = option.key
		table.insert(self.options, option)
		return option
	end

	function parent:AddSlider(option: any): any
		option = if typeof(option) == "table" then option else {}
		option.text     = tostring(option.text)
		option.min      = if typeof(option.min) == "number" then option.min else 0
		option.max      = if typeof(option.max) == "number" then option.max else 0
		option.dual     = if typeof(option.dual) == "boolean" then option.dual else false
		option.value    = math.clamp(if typeof(option.value) == "number" then option.value else option.min, option.min, option.max)
		option.value2   = if typeof(option.value2) == "number" then option.value2 else option.max
		option.callback = if typeof(option.callback) == "function" then option.callback else function() end
		option.float    = if typeof(option.float) == "number" then option.float else 1
		option.type     = "slider"
		option.position = #self.options
		option.flag     = option.flag or option.text
		library.flags[option.flag] = option.value
		table.insert(self.options, option)
		return option
	end

	function parent:AddList(option: any): any
		option = if typeof(option) == "table" then option else {}
		option.text     = tostring(option.text)
		option.values   = if typeof(option.values) == "table" then option.values else {}
		option.value    = tostring(option.value or option.values[1] or "")
		option.callback = if typeof(option.callback) == "function" then option.callback else function() end
		option.open     = false
		option.type     = "list"
		option.position = #self.options
		option.flag     = option.flag or option.text
		library.flags[option.flag] = option.value
		table.insert(self.options, option)
		return option
	end

	function parent:AddBox(option: any): any
		option = if typeof(option) == "table" then option else {}
		option.text     = tostring(option.text)
		option.value    = tostring(option.value or "")
		option.callback = if typeof(option.callback) == "function" then option.callback else function() end
		option.type     = "box"
		option.position = #self.options
		option.flag     = option.flag or option.text
		library.flags[option.flag] = option.value
		table.insert(self.options, option)
		return option
	end

	function parent:AddColor(option: any): any
		option = if typeof(option) == "table" then option else {}
		option.text     = tostring(option.text)
		option.color    = if typeof(option.color) == "table"
			then Color3.new(tonumber(option.color[1]) or 1, tonumber(option.color[2]) or 1, tonumber(option.color[3]) or 1)
			else (option.color or Color3.new(1, 1, 1))
		option.callback = if typeof(option.callback) == "function" then option.callback else function() end
		option.open     = false
		option.type     = "color"
		option.position = #self.options
		option.flag     = option.flag or option.text
		library.flags[option.flag] = option.color
		table.insert(self.options, option)
		return option
	end

	function parent:AddFolder(folderTitle: string): any
		local option: any = {}
		option.title    = tostring(folderTitle)
		option.options  = {}
		option.open     = false
		option.type     = "folder"
		option.position = #self.options
		table.insert(self.options, option)
		attachFunctions(option)

		function option:init()
			createOptionHolder(self.title, parent.content, self, true)
			loadOptions(self, parent)
		end

		return option
	end
end

