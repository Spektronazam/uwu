			ColorSequenceKeypoint.new(0.66, Color3.fromRGB(0, 0, 255)),
			ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
			ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255, 0, 0)),
		}),
		Parent = hueBar,
	})

	local hueCursor = create("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.5, 0, 0, 0),
		Size = UDim2.new(1, 4, 0, 2),
		BorderSizePixel = 0,
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		Parent = hueBar,
	})

	local hexBg = rounded("ImageLabel", {
		Position = UDim2.new(0, 8, 0, 146),
		Size = UDim2.new(1, -16, 0, 22),
		ImageColor3 = Color3.fromRGB(20, 20, 20),
		Parent = picker,
	})

	local hexLabel = create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 6, 0, 0),
		Size = UDim2.new(1, -12, 1, 0),
		Text = "",
		Font = Enum.Font.GothamSemibold,
		TextSize = 12,
		TextColor3 = Color3.fromRGB(220, 220, 220),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = hexBg,
	})

	option.main = main
	library.flags[option.flag] = option.color

	local hue, sat, val = Color3.toHSV(option.color)
	local draggingSV = false
	local draggingHue = false

	local function refreshHeight(instant)
		local height = option.open and pickerHeight or 0
		picker.Visible = option.open

		local targetMain = UDim2.new(1, 0, 0, baseHeight + (option.open and (pickerHeight + 4) or 0))
		local targetPicker = UDim2.new(1, 0, 0, height)
		local targetRot = option.open and 90 or 180

		if instant then
			picker.Size = targetPicker
			main.Size = targetMain
			arrow.Rotation = targetRot
		else
			tween(picker, TWEEN_FAST, { Size = targetPicker })
			tween(main, TWEEN_FAST, { Size = targetMain })
			tween(arrow, TWEEN_FAST, { Rotation = targetRot })
		end

		refreshHolderChain(parent, true)
	end

	local function applyColor(silent)
		local color = Color3.fromHSV(hue, sat, val)
		option.color = color
		library.flags[option.flag] = color

		satVal.ImageColor3 = Color3.fromHSV(hue, 1, 1)
		satValCursor.Position = UDim2.fromScale(sat, 1 - val)
		hueCursor.Position = UDim2.new(0.5, 0, hue, 0)
		preview.ImageColor3 = color
		hexLabel.Text = colorToHex(color)

		if not silent then
			safeCall(option.text, option.callback, color)
		end
	end

	local function setSVFromPos(x, y)
		local px = math.clamp(x - satVal.AbsolutePosition.X, 0, satVal.AbsoluteSize.X)
		local py = math.clamp(y - satVal.AbsolutePosition.Y, 0, satVal.AbsoluteSize.Y)
		sat = math.clamp(px / satVal.AbsoluteSize.X, 0, 1)
		val = 1 - math.clamp(py / satVal.AbsoluteSize.Y, 0, 1)
		applyColor(false)
	end

	local function setHueFromPos(y)
		local py = math.clamp(y - hueBar.AbsolutePosition.Y, 0, hueBar.AbsoluteSize.Y)
		hue = math.clamp(py / hueBar.AbsoluteSize.Y, 0, 1)
		applyColor(false)
	end

	function option:SetColor(newColor, silent)
		local h, s, v = Color3.toHSV(newColor)
		hue = h
		sat = s
		val = v
		applyColor(silent)
	end

	function option:Close()
		option.open = false
		refreshHeight(false)
	end

	applyColor(true)
	refreshHeight(true)

	option._maid:GiveTask(button.MouseButton1Click:Connect(function()
		option.open = not option.open
		refreshHeight(false)
	end))

	option._maid:GiveTask(satVal.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			draggingSV = true
			setSVFromPos(input.Position.X, input.Position.Y)
		end
	end))

	option._maid:GiveTask(hueBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			draggingHue = true
			setHueFromPos(input.Position.Y)
		end
	end))

	option._maid:GiveTask(InputService.InputChanged:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseMovement then
			return
		end

		if draggingSV then
			setSVFromPos(input.Position.X, input.Position.Y)
		elseif draggingHue then
			setHueFromPos(input.Position.Y)
		end
	end))

	option._maid:GiveTask(InputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			draggingSV = false
			draggingHue = false
		end
	end))

	if option.fireInit then
		task.defer(function()
			safeCall(option.text, option.callback, option.color)
		end)
	end
end

applySearchToHolder = function(holder, query, forceShow)
	local loweredTitle = string.lower(holder.title or "")
	local titleMatch = false

	if query ~= "" and string.find(loweredTitle, query, 1, true) then
		titleMatch = true
	end

	local forceAll = forceShow or titleMatch
	local anyVisible = false

	for _, option in ipairs(holder.options) do
		if option._isHolder then
			local childVisible = applySearchToHolder(option, query, forceAll)

			if option.main then
				option.main.Visible = (query == "") or childVisible or forceAll
			end

			if query ~= "" then
				if childVisible or forceAll then
					if option._savedSearchOpen == nil then
						option._savedSearchOpen = option.open
					end
					setHolderOpen(option, true, true)
				end
			else
				if option._savedSearchOpen ~= nil then
					setHolderOpen(option, option._savedSearchOpen, true)
					option._savedSearchOpen = nil
				end

				if option.main then
					option.main.Visible = true
				end
			end

			anyVisible = anyVisible or childVisible or forceAll
		else
			local hay = string.lower((option.text or "") .. " " .. (option.flag or ""))
			local visible = (query == "") or forceAll or (string.find(hay, query, 1, true) ~= nil)

			if option.main then
				option.main.Visible = visible
			end

			anyVisible = anyVisible or visible
		end
	end

	holder:_RefreshHeight(true)
	return anyVisible or titleMatch
end

function library:SearchFor(query)
	query = string.lower(tostring(query or ""))
	currentSearch = query

	for _, window in ipairs(self.windows) do
		local visible = applySearchToHolder(window, query, false)

		if query ~= "" then
			if visible then
				if window._savedSearchOpen == nil then
					window._savedSearchOpen = window.open
				end
				setHolderOpen(window, true, true)
			end

			if window.main then
				window.main.Visible = visible
			end
		else
			if window._savedSearchOpen ~= nil then
				setHolderOpen(window, window._savedSearchOpen, true)
				window._savedSearchOpen = nil
			end

			if window.main then
				window.main.Visible = true
			end
		end
	end
end

function library:CreateWindow(title)
	local window = createHolderRecord(title, #self.windows + 1, false)
	table.insert(self.windows, window)

	if self.base then
		window:_Mount(self.base)

		if window.main and window._targetPosition then
			window.main.Position = UDim2.new(0, -window.main.AbsoluteSize.X - 40, 0, window._targetPosition.Y.Offset)
			window.main.ImageTransparency = 1

			tween(window.main, TWEEN_ENTER, {
				Position = window._targetPosition,
				ImageTransparency = 0,
			})
		end
	end

	return window
end

function library:SetAccent(color)
	self.accent = color

	for i = #accentBindings, 1, -1 do
		local entry = accentBindings[i]

		if entry.dead then
			table.remove(accentBindings, i)
		elseif entry.type == "property" then
			if not entry.instance or entry.instance.Parent == nil then
				table.remove(accentBindings, i)
			else
				if entry.transform then
					entry.instance[entry.property] = entry.transform(color)
				else
					entry.instance[entry.property] = color
				end
			end
		elseif entry.type == "callback" then
			local ok = pcall(entry.callback, color)
			if not ok then
				table.remove(accentBindings, i)
			end
		end
	end
end

local function playLoader(gui)
	local loader = create("Frame", {
		AnchorPoint = Vector2.new(0.5, 0),
		Position = UDim2.new(0.5, 0, 0, 18),
		Size = UDim2.new(0, 46, 0, 12),
		BackgroundTransparency = 1,
		Parent = gui,
	})

	local dots = {}

	for i = 1, 3 do
		local dot = create("Frame", {
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(0, ((i - 1) * 16) + 7, 0.5, 0),
			Size = UDim2.new(0, 6, 0, 6),
			BorderSizePixel = 0,
			BackgroundColor3 = (i == 2) and library.accent or Color3.fromRGB(60, 60, 60),
			Parent = loader,
		})
		create("UICorner", {
			CornerRadius = UDim.new(1, 0),
			Parent = dot,
		})
		table.insert(dots, dot)
	end

	local running = true
	task.spawn(function()
		local start = os.clock()
		while running and os.clock() - start < 0.85 do
			for i, dot in ipairs(dots) do
				if dot.Parent then
					local phase = (os.clock() * 6) + i
					local s = 5 + ((math.sin(phase) + 1) * 1.5)
					dot.Size = UDim2.new(0, s, 0, s)
				end
			end
			RunService.Heartbeat:Wait()
		end
	end)

	task.delay(0.9, function()
		running = false
		if loader.Parent then
			loader:Destroy()
		end
	end)
end

