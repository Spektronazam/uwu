------------------------------------------------------------------------
-- Drag helpers
------------------------------------------------------------------------
local function updateDrag(input: InputObject)
	if not dragStart or not startPos or not dragObject then return end
	local delta = input.Position - dragStart
	local yPos = math.max(startPos.Y.Offset + delta.Y, -36)
	local goal  = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, yPos)
	tween(dragObject, TweenInfo.new(0.08, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), { Position = goal })
end

------------------------------------------------------------------------
-- createOptionHolder  (window / folder column)
------------------------------------------------------------------------
local function createOptionHolder(holderTitle: string, parent: Instance, parentTable: any, subHolder: boolean?)
	local size = if subHolder then SUB_HEADER_HEIGHT else HEADER_HEIGHT

	parentTable.main = create("ImageButton", {
		LayoutOrder = if subHolder then parentTable.position else 0,
		Position = UDim2.new(0, SLIDE_LEFT_PAD + (260 * (parentTable.position or 0)), 0, 60),
		Size = UDim2.new(0, WINDOW_WIDTH, 0, size),
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = Color3.fromRGB(20, 20, 20),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.04,
		ClipsDescendants = true,
		ImageTransparency = 1, -- start invisible for entrance anim
		Parent = parent,
	}) :: ImageButton

	-- store original for exit undo
	windowOriginals[parentTable] = {
		pos  = parentTable.main.Position,
		size = parentTable.main.Size,
	}

	local roundBg: ImageLabel? = nil
	if not subHolder then
		roundBg = create("ImageLabel", {
			Size = UDim2.new(1, 0, 0, size),
			BackgroundTransparency = 1,
			Image = ROUND_IMAGE,
			ImageColor3 = if parentTable.open
				then Color3.fromRGB(10, 10, 10)
				else Color3.fromRGB(6, 6, 6),
			ScaleType = Enum.ScaleType.Slice,
			SliceCenter = Rect.new(100, 100, 100, 100),
			SliceScale = 0.04,
			Parent = parentTable.main,
		})
	end

	local title = create("TextLabel", {
		Size = UDim2.new(1, 0, 0, size),
		BackgroundTransparency = if subHolder then 0 else 1,
		BackgroundColor3 = Color3.fromRGB(10, 10, 10),
		BorderSizePixel = 0,
		Text = holderTitle,
		TextSize = if subHolder then 16 else 17,
		Font = Enum.Font.GothamBold,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		Parent = parentTable.main,
	}) :: TextLabel

	-- close/open arrow area
	local closeHolder = create("Frame", {
		Position = UDim2.new(1, 0, 0, 0),
		Size = UDim2.new(-1, 0, 1, 0),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		BackgroundTransparency = 1,
		Parent = title,
	}) :: Frame

	local closeArrow = create("ImageLabel", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.5, 0, 0.5, 0),
		Size = UDim2.new(1, -size - 10, 1, -size - 10),
		Rotation = if parentTable.open then 90 else 180,
		BackgroundTransparency = 1,
		Image = ARROW_IMAGE,
		ImageColor3 = if parentTable.open
			then Color3.fromRGB(50, 50, 50)
			else Color3.fromRGB(30, 30, 30),
		ScaleType = Enum.ScaleType.Fit,
		Parent = closeHolder,
	}) :: ImageLabel

	parentTable.content = create("Frame", {
		Position = UDim2.new(0, 0, 0, size),
		Size = UDim2.new(1, 0, 1, -size),
		BackgroundTransparency = 1,
		Parent = parentTable.main,
	}) :: Frame

	local layout = create("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = parentTable.content,
	}) :: UIListLayout

	-- Resize handle (bottom-right, only for top-level windows)
	local resizeHandle: Frame? = nil
	if not subHolder then
		resizeHandle = create("Frame", {
			AnchorPoint = Vector2.new(1, 1),
			Position = UDim2.new(1, 0, 1, 0),
			Size = UDim2.new(0, 14, 0, 14),
			BackgroundTransparency = 1,
			ZIndex = 5,
			Parent = parentTable.main,
		})

		-- little grip dots
		create("Frame", {
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(0.6, 0, 0.6, 0),
			Size = UDim2.new(0, 3, 0, 3),
			BackgroundColor3 = Color3.fromRGB(60, 60, 60),
			BorderSizePixel = 0,
			Parent = resizeHandle,
		})
		create("Frame", {
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(0.3, 0, 0.85, 0),
			Size = UDim2.new(0, 3, 0, 3),
			BackgroundColor3 = Color3.fromRGB(60, 60, 60),
			BorderSizePixel = 0,
			Parent = resizeHandle,
		})
		create("Frame", {
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(0.85, 0, 0.3, 0),
			Size = UDim2.new(0, 3, 0, 3),
			BackgroundColor3 = Color3.fromRGB(60, 60, 60),
			BorderSizePixel = 0,
			Parent = resizeHandle,
		})

		-- Resize logic
		local resizing = false
		local resizeStart: Vector3? = nil
		local originalWidth: number = WINDOW_WIDTH

		resizeHandle.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				resizing = true
				resizeStart = input.Position
				originalWidth = parentTable.main.AbsoluteSize.X
			end
		end)

		table.insert(connections, InputService.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement and resizing and resizeStart then
				local delta = input.Position.X - resizeStart.X
				local newW  = math.clamp(originalWidth + delta, MIN_WINDOW_WIDTH, MAX_WINDOW_WIDTH)
				parentTable.main.Size = UDim2.new(0, newW, parentTable.main.Size.Y.Scale, parentTable.main.Size.Y.Offset)
			end
		end))

		table.insert(connections, InputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				resizing = false
			end
		end))
	end

	-- Auto-resize content height
	layout.Changed:Connect(function()
		parentTable.content.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y)
		local goal = if #parentTable.options > 0 and parentTable.open
			then UDim2.new(0, parentTable.main.Size.X.Offset, 0, layout.AbsoluteContentSize.Y + size)
			else UDim2.new(0, parentTable.main.Size.X.Offset, 0, size)
		parentTable.main.Size = goal
	end)

	if not subHolder then
		create("UIPadding", { Parent = parentTable.content })

		-- Dragging on title
		title.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragObject = parentTable.main
				dragging = true
				dragStart = input.Position
				startPos = dragObject.Position
			end
		end)
		title.InputChanged:Connect(function(input)
			if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
				dragInput = input
			end
		end)
		title.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = false
			end
		end)
	end

	-- Toggle open/close section
	closeHolder.InputBegan:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
		parentTable.open = not parentTable.open

		tween(closeArrow, TWEEN_MED, {
			Rotation   = if parentTable.open then 90 else 180,
			ImageColor3 = if parentTable.open then Color3.fromRGB(50, 50, 50) else Color3.fromRGB(30, 30, 30),
		})

		if subHolder then
			tween(title, TWEEN_MED, {
				BackgroundColor3 = if parentTable.open then Color3.fromRGB(16, 16, 16) else Color3.fromRGB(10, 10, 10),
			})
		elseif roundBg then
			tween(roundBg, TWEEN_MED, {
				ImageColor3 = if parentTable.open then Color3.fromRGB(10, 10, 10) else Color3.fromRGB(6, 6, 6),
			})
		end

		local w = parentTable.main.Size.X.Offset
		local goalSize = if #parentTable.options > 0 and parentTable.open
			then UDim2.new(0, w, 0, layout.AbsoluteContentSize.Y + size)
			else UDim2.new(0, w, 0, size)
		parentTable.main:TweenSize(goalSize, Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.25, true)
	end)

	function parentTable:SetTitle(newTitle: string)
		title.Text = tostring(newTitle)
	end

	-- Reset to original size (used on config load & exit undo)
	function parentTable:ResetSize()
		local orig = windowOriginals[self]
		if not orig then return end
		tween(self.main, TWEEN_SLOW, { Size = orig.size })
	end

	return parentTable
end

