------------------------------------------------------------------------
-- Types
------------------------------------------------------------------------
export type Flag = string | boolean | number | Color3

export type OptionBase = {
	text: string,
	type: string,
	position: number,
	flag: string,
}

export type ToggleOption = OptionBase & {
	state: boolean,
	callback: (boolean) -> (),
	SetState: (self: ToggleOption, state: boolean) -> (),
}

export type ButtonOption = OptionBase & {
	callback: () -> (),
}

export type SliderOption = OptionBase & {
	min: number,
	max: number,
	value: number,
	value2: number,
	float: number,
	dual: boolean,
	callback: (number) -> (),
	SetValue: (self: SliderOption, value: number) -> (),
}

export type ListOption = OptionBase & {
	values: { string },
	value: string,
	open: boolean,
	callback: (string) -> (),
	SetValue: (self: ListOption, value: string) -> (),
	AddValue: (self: ListOption, value: string) -> (),
	RemoveValue: (self: ListOption, value: string) -> (),
	Close: (self: ListOption) -> (),
}

export type BoxOption = OptionBase & {
	value: string,
	callback: (string, boolean?) -> (),
	SetValue: (self: BoxOption, value: string, enter: boolean?) -> (),
}

export type BindOption = OptionBase & {
	key: string,
	hold: boolean,
	callback: (boolean?) -> (),
	SetKey: (self: BindOption, key: any) -> (),
}

export type ColorOption = OptionBase & {
	color: Color3,
	open: boolean,
	callback: (Color3) -> (),
	SetColor: (self: ColorOption, newColor: Color3) -> (),
	Close: (self: ColorOption) -> (),
}

export type Window = {
	title: string,
	options: { any },
	open: boolean,
	canInit: boolean,
	init: boolean,
	position: number,
	main: ImageButton?,
	content: Frame?,
	SetTitle: (self: Window, title: string) -> (),
	AddLabel: (self: Window, option: any) -> any,
	AddToggle: (self: Window, option: any) -> ToggleOption,
	AddButton: (self: Window, option: any) -> ButtonOption,
	AddBind: (self: Window, option: any) -> BindOption,
	AddSlider: (self: Window, option: any) -> SliderOption,
	AddList: (self: Window, option: any) -> ListOption,
	AddBox: (self: Window, option: any) -> BoxOption,
	AddColor: (self: Window, option: any) -> ColorOption,
	AddFolder: (self: Window, title: string) -> any,
}

export type Library = {
	flags: { [string]: Flag },
	windows: { Window },
	open: boolean,
	accent: Color3,
	base: ScreenGui?,
	CreateWindow: (self: Library, title: string) -> Window,
	Init: (self: Library) -> ScreenGui?,
	Close: (self: Library) -> (),
	SetAccent: (self: Library, color: Color3) -> (),
	SearchFor: (self: Library, query: string) -> (),
}

