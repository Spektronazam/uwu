			inputValue:CaptureFocus()
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = true
			if not focused then
				tween(outline, TWEEN_FAST, { ImageColor3 = Color3.fromRGB(100, 100, 100) })
