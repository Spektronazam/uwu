	option.resetText  = _resetTxt
	option.undoColor  = undoBtn
	option.undoText   = _undoTxt
	option.setColor   = setBtn
	option.setText     = _setTxt
	option.rainbow    = rainBtn
	option.rainbowText = rainTxt

	resetBtn.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 and not rainbowEnabled then
			previousColors = { originalColor }
			option:SetColor(originalColor)
		end
	end)

	undoBtn.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 and not rainbowEnabled then
			local n = if #previousColors == 1 then 0 else 1
			option:SetColor(previousColors[#previousColors - n])
			if #previousColors ~= 1 then
				table.remove(previousColors, #previousColors)
			end
		end
	end)

	setBtn.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 and not rainbowEnabled then
			table.insert(previousColors, currentColor)
			option:SetColor(currentColor)
		end
	end)

	rainBtn.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			rainbowEnabled = not rainbowEnabled
			if rainbowEnabled then
				rainbowLoop = RunService.Heartbeat:Connect(function()
					option:SetColor(chromaColor)
					rainTxt.TextColor3 = chromaColor
				end)
			else
				if rainbowLoop then rainbowLoop:Disconnect() end
				option:SetColor(previousColors[#previousColors])
				rainTxt.TextColor3 = Color3.fromRGB(255, 255, 255)
			end
		end
	end)

	return option
