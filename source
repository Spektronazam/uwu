local function refreshHolderChain(holder, instant)
	if holder and holder._RefreshHeight then
		holder:_RefreshHeight(instant)
	end
end

local function setHolderOpen(holder, state, instant)
	if holder and holder._SetOpen then
		holder:_SetOpen(state, instant)
	end
end

local function normalizeOption(holder, option, kind)
	option = option or {}
	option.type = kind
	option.position = #holder.options + 1
	option.text = tostring(option.text or kind)
	option.flag = tostring(option.flag or sanitizeFlag(option.text))
	option.callback = option.callback or function() end
	option._maid = option._maid or newMaid()
	option._parentHolder = holder
	return option
end

createHolderRecord = function(title, position, isFolder)
	local holder = {
		title = tostring(title),
		options = {},
		open = true,
		canInit = true,
		init = false,
		position = position,
		main = nil,
		content = nil,
		layout = nil,
		_headerHeight = isFolder and SUB_HEADER_HEIGHT or HEADER_HEIGHT,
		_isHolder = true,
		_isFolder = isFolder == true,
		_parentHolder = nil,
		_maid = newMaid(),
		_arrow = nil,
		_headerBg = nil,
		_titleLabel = nil,
		_dragButton = nil,
		_resizeHandle = nil,
		_targetPosition = nil,
		_savedSearchOpen = nil,
	}

	function holder:SetTitle(newTitle)
		self.title = tostring(newTitle)
		if self._titleLabel then
			self._titleLabel.Text = self.title
		end
	end

	function holder:_RefreshHeight(instant)
		if not self.main or not self.content or not self.layout then
			return
		end

		local contentHeight = self.layout.AbsoluteContentSize.Y
		self.content.Size = UDim2.new(1, 0, 0, contentHeight)
		self.content.Visible = self.open

		local targetHeight = self._headerHeight
		if self.open then
			targetHeight = targetHeight + contentHeight
		end

		local targetSize
		if self._isFolder then
			targetSize = UDim2.new(1, 0, 0, targetHeight)
		else
			targetSize = UDim2.new(0, self.main.Size.X.Offset, 0, targetHeight)
		end

		if instant then
			self.main.Size = targetSize
		else
			tween(self.main, TWEEN_MED, { Size = targetSize })
		end

		if self._parentHolder then
			self._parentHolder:_RefreshHeight(instant)
		end
	end

	function holder:_SetOpen(state, instant)
		self.open = state

		if self._arrow then
			local arrowRotation = 180
			local arrowColor = Color3.fromRGB(36, 36, 36)

			if state then
				arrowRotation = 90
				arrowColor = Color3.fromRGB(56, 56, 56)
			end

			if instant then
				self._arrow.Rotation = arrowRotation
				self._arrow.ImageColor3 = arrowColor
			else
				tween(self._arrow, TWEEN_MED, {
					Rotation = arrowRotation,
					ImageColor3 = arrowColor,
				})
			end
		end

		if self._headerBg then
			local bgColor = Color3.fromRGB(8, 8, 8)
			if state then
				bgColor = Color3.fromRGB(12, 12, 12)
			end

			if instant then
				self._headerBg.ImageColor3 = bgColor
			else
				tween(self._headerBg, TWEEN_MED, { ImageColor3 = bgColor })
			end
		end

		self:_RefreshHeight(instant)
	end

	function holder:ResetSize()
		local original = windowOriginals[self]
		if original and self.main and not self._isFolder then
			tween(self.main, TWEEN_SLOW, { Size = original.size })
		end
	end

	function holder:_Mount(parent)
		if self.main then
			return
		end

		local main
		if self._isFolder then
			main = rounded("ImageButton", {
				LayoutOrder = self.position,
				Size = UDim2.new(1, 0, 0, self._headerHeight),
				ImageColor3 = Color3.fromRGB(18, 18, 18),
				ClipsDescendants = true,
				AutoButtonColor = false,
				Parent = parent,
			})
		else
			local targetPos = UDim2.new(0, WINDOW_X + ((self.position - 1) * WINDOW_GAP), 0, WINDOW_Y)
			self._targetPosition = targetPos

			main = rounded("ImageButton", {
				Position = targetPos,
				Size = UDim2.new(0, WINDOW_WIDTH, 0, self._headerHeight),
				ImageColor3 = Color3.fromRGB(20, 20, 20),
				ImageTransparency = 0,
				ClipsDescendants = true,
				AutoButtonColor = false,
				Parent = parent,
			})

			windowOriginals[self] = {
				pos = targetPos,
				size = main.Size,
			}
		end

		self.main = main
		self._maid:GiveTask(main)

		local headerBg = rounded("ImageLabel", {
			Size = UDim2.new(1, 0, 0, self._headerHeight),
			ImageColor3 = self.open and Color3.fromRGB(12, 12, 12) or Color3.fromRGB(8, 8, 8),
			Parent = main,
		})
		self._headerBg = headerBg

		local titleLabel = create("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 10, 0, 0),
			Size = UDim2.new(1, -44, 1, 0),
			Text = self.title,
			Font = self._isFolder and Enum.Font.GothamSemibold or Enum.Font.GothamBold,
			TextSize = self._isFolder and 15 or 16,
			TextColor3 = Color3.fromRGB(255, 255, 255),
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = main,
		})
		self._titleLabel = titleLabel

		local dragButton = create("TextButton", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, -36, 0, self._headerHeight),
			Text = "",
			AutoButtonColor = false,
			Parent = main,
		})
		self._dragButton = dragButton

		local arrowButton = create("TextButton", {
			AnchorPoint = Vector2.new(1, 0),
			Position = UDim2.new(1, 0, 0, 0),
			Size = UDim2.new(0, 36, 0, self._headerHeight),
			BackgroundTransparency = 1,
			Text = "",
			AutoButtonColor = false,
			Parent = main,
		})

		local arrow = create("ImageLabel", {
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(0.5, 0, 0.5, 0),
			Size = UDim2.new(0, 14, 0, 14),
			BackgroundTransparency = 1,
			Image = ARROW_IMAGE,
			ImageColor3 = self.open and Color3.fromRGB(56, 56, 56) or Color3.fromRGB(36, 36, 36),
			Rotation = self.open and 90 or 180,
			Parent = arrowButton,
		})
		self._arrow = arrow

		local content = create("Frame", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 0, 0, self._headerHeight),
			Size = UDim2.new(1, 0, 0, 0),
			Visible = self.open,
			Parent = main,
		})
		self.content = content

		create("UIPadding", {
			PaddingLeft = UDim.new(0, OPTION_PAD_X),
			PaddingRight = UDim.new(0, OPTION_PAD_X),
			PaddingTop = UDim.new(0, 4),
			PaddingBottom = UDim.new(0, 6),
			Parent = content,
		})

		local layout = create("UIListLayout", {
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 4),
			Parent = content,
		})
		self.layout = layout

		self._maid:GiveTask(layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			self:_RefreshHeight(true)
		end))

		self._maid:GiveTask(arrowButton.MouseButton1Click:Connect(function()
			self:_SetOpen(not self.open, false)
		end))

		if self._isFolder then
			self._maid:GiveTask(dragButton.MouseButton1Click:Connect(function()
				self:_SetOpen(not self.open, false)
			end))
		else
			local dragging = false
			local dragStart = nil
			local startPos = nil

			self._maid:GiveTask(dragButton.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
					dragStart = input.Position
					startPos = self.main.Position
				end
			end))

			self._maid:GiveTask(InputService.InputChanged:Connect(function(input)
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement and dragStart and startPos then
					local delta = input.Position - dragStart
					local y = math.max(startPos.Y.Offset + delta.Y, -36)
					self.main.Position = UDim2.new(
						startPos.X.Scale,
						startPos.X.Offset + delta.X,
						startPos.Y.Scale,
						y
					)
				end
			end))

			self._maid:GiveTask(InputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
				end
			end))

			local handle = create("Frame", {
				AnchorPoint = Vector2.new(1, 1),
				Position = UDim2.new(1, 0, 1, 0),
				Size = UDim2.new(0, 14, 0, 14),
				BackgroundTransparency = 1,
				ZIndex = 5,
				Parent = main,
			})
			self._resizeHandle = handle

			for _, pos in ipairs({
				Vector2.new(4, 10),
				Vector2.new(10, 4),
				Vector2.new(9, 9),
			}) do
				create("Frame", {
					Position = UDim2.new(0, pos.X, 0, pos.Y),
					Size = UDim2.new(0, 3, 0, 3),
					BorderSizePixel = 0,
					BackgroundColor3 = Color3.fromRGB(60, 60, 60),
					Parent = handle,
				})
			end

			local resizing = false
			local resizeStart = nil
			local startWidth = WINDOW_WIDTH

			self._maid:GiveTask(handle.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					resizing = true
					resizeStart = input.Position
					startWidth = self.main.AbsoluteSize.X
				end
			end))

			self._maid:GiveTask(InputService.InputChanged:Connect(function(input)
				if resizing and input.UserInputType == Enum.UserInputType.MouseMovement and resizeStart then
					local deltaX = input.Position.X - resizeStart.X
					local newWidth = math.clamp(startWidth + deltaX, MIN_WINDOW_WIDTH, MAX_WINDOW_WIDTH)
					self.main.Size = UDim2.new(0, newWidth, 0, self.main.Size.Y.Offset)
					self:_RefreshHeight(true)
				end
			end))

			self._maid:GiveTask(InputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					resizing = false
				end
			end))
		end

		for _, option in ipairs(self.options) do
			if option._isHolder then
				option:_Mount(content)
			else
				option._creator(option, self)
			end
		end

		self.init = true
		self:_RefreshHeight(true)
	end

	attachHolderMethods(holder)
	return holder
end

local function addOptionObject(holder, option, creator)
	option._creator = creator
	table.insert(holder.options, option)

	if holder.content then
		creator(option, holder)
		holder:_RefreshHeight(true)

		if currentSearch ~= "" then
			library:SearchFor(currentSearch)
		end
	end

	return option
end

attachHolderMethods = function(holder)
	function holder:AddLabel(option)
		option = normalizeOption(self, option, "label")
		return addOptionObject(self, option, createLabel)
	end

	function holder:AddToggle(option)
		option = normalizeOption(self, option, "toggle")
		option.state = option.state == true
		warnDuplicateFlag(option.flag)
		return addOptionObject(self, option, createToggle)
	end

	function holder:AddButton(option)
		option = normalizeOption(self, option, "button")
		return addOptionObject(self, option, createButton)
	end

	function holder:AddBind(option)
		option = normalizeOption(self, option, "bind")
		option.key = tostring(option.key or "RightShift")
		option.hold = option.hold == true
		warnDuplicateFlag(option.flag)
		return addOptionObject(self, option, createBind)
	end

	function holder:AddSlider(option)
		option = normalizeOption(self, option, "slider")
		option.min = tonumber(option.min or 0) or 0
		option.max = tonumber(option.max or 100) or 100
		option.float = tonumber(option.float or 1) or 1
		option.value = tonumber(option.value)
		if option.value == nil then
			option.value = option.min
		end
		warnDuplicateFlag(option.flag)
		return addOptionObject(self, option, createSlider)
	end

	function holder:AddList(option)
		option = normalizeOption(self, option, "list")
		option.values = option.values or {}
		option.value = tostring(option.value or option.values[1] or "")
		option.open = option.open == true
		warnDuplicateFlag(option.flag)
		return addOptionObject(self, option, createList)
	end

	function holder:AddBox(option)
		option = normalizeOption(self, option, "box")
		option.value = tostring(option.value or "")
		warnDuplicateFlag(option.flag)
		return addOptionObject(self, option, createBox)
	end

	function holder:AddColor(option)
		option = normalizeOption(self, option, "color")
		option.color = option.color or library.accent
		option.open = option.open == true
		warnDuplicateFlag(option.flag)
		return addOptionObject(self, option, createColor)
	end

	function holder:AddFolder(title)
		local folder = createHolderRecord(title, #self.options + 1, true)
		folder._parentHolder = self
		table.insert(self.options, folder)

		if self.content then
			folder:_Mount(self.content)
			self:_RefreshHeight(true)

			if currentSearch ~= "" then
				library:SearchFor(currentSearch)
			end
		end

		return folder
	end
end

createLabel = function(option, parent)
	local main = create("TextLabel", {
		LayoutOrder = option.position,
		Size = UDim2.new(1, 0, 0, 24),
		BackgroundTransparency = 1,
		Text = " " .. option.text,
		TextSize = 15,
		Font = Enum.Font.Gotham,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = parent.content,
	})

	option.main = main

	function option:SetText(text)
		self.text = tostring(text)
		main.Text = " " .. self.text
	end
end

