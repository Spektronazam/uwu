-- Label ---------------------------------------------------------------
local function createLabel(option: any, parent: any)
	local main = create("TextLabel", {
		LayoutOrder = option.position,
		Size = UDim2.new(1, 0, 0, 26),
		BackgroundTransparency = 1,
		Text = " " .. option.text,
		TextSize = 17,
		Font = Enum.Font.Gotham,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = parent.content,
	})

	table.insert(allOptionRefs, { label = main, option = option, parent = parent })

	setmetatable(option, {
		__newindex = function(_t, i, v)
			if i == "Text" then
				main.Text = " " .. tostring(v)
			end
		end,
	})
end

-- Toggle --------------------------------------------------------------
local function createToggle(option: any, parent: any)
	local main = create("TextLabel", {
		LayoutOrder = option.position,
		Size = UDim2.new(1, 0, 0, 31),
		BackgroundTransparency = 1,
		Text = " " .. option.text,
		TextSize = 17,
		Font = Enum.Font.Gotham,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = parent.content,
	}) :: TextLabel

	table.insert(allOptionRefs, { label = main, option = option, parent = parent })

	local tickboxOutline = create("ImageLabel", {
		Position = UDim2.new(1, -6, 0, 4),
		Size = UDim2.new(-1, 10, 1, -10),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = if option.state then library.accent else Color3.fromRGB(100, 100, 100),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent = main,
	})

	local tickboxInner = create("ImageLabel", {
		Position = UDim2.new(0, 2, 0, 2),
		Size = UDim2.new(1, -4, 1, -4),
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = if option.state then library.accent else Color3.fromRGB(20, 20, 20),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent = tickboxOutline,
	})

	local checkmarkHolder = create("Frame", {
		Position = UDim2.new(0, 4, 0, 4),
		Size = if option.state then UDim2.new(1, -8, 1, -8) else UDim2.new(0, 0, 1, -8),
		BackgroundTransparency = 1,
		ClipsDescendants = true,
		Parent = tickboxOutline,
	})

	create("ImageLabel", {
		Size = UDim2.new(1, 0, 1, 0),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		BackgroundTransparency = 1,
		Image = CHECK_IMAGE,
		ImageColor3 = Color3.fromRGB(20, 20, 20),
		Parent = checkmarkHolder,
	})

	local inContact = false

	main.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			option:SetState(not option.state)
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = true
			if not option.state then
				tween(tickboxOutline, TWEEN_FAST, { ImageColor3 = Color3.fromRGB(140, 140, 140) })
			end
		end
	end)

	main.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = false
			if not option.state then
				tween(tickboxOutline, TWEEN_FAST, { ImageColor3 = Color3.fromRGB(100, 100, 100) })
			end
		end
	end)

	function option:SetState(state: boolean)
		library.flags[self.flag] = state
		self.state = state
		checkmarkHolder:TweenSize(
			if state then UDim2.new(1, -8, 1, -8) else UDim2.new(0, 0, 1, -8),
			Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true
		)
		tween(tickboxInner, TWEEN_MED, {
			ImageColor3 = if state then library.accent else Color3.fromRGB(20, 20, 20),
		})
		if state then
			tween(tickboxOutline, TWEEN_MED, { ImageColor3 = library.accent })
		else
			tween(tickboxOutline, TWEEN_MED, {
				ImageColor3 = if inContact then Color3.fromRGB(140, 140, 140) else Color3.fromRGB(100, 100, 100),
			})
		end
		self.callback(state)
	end

	if option.state then
		task.delay(1, function() option.callback(true) end)
	end

	setmetatable(option, {
		__newindex = function(_t, i, v)
			if i == "Text" then main.Text = " " .. tostring(v) end
		end,
	})
end

-- Button --------------------------------------------------------------
local function createButton(option: any, parent: any)
	local main = create("TextLabel", {
		ZIndex = 2,
		LayoutOrder = option.position,
		Size = UDim2.new(1, 0, 0, 34),
		BackgroundTransparency = 1,
		Text = " " .. option.text,
		TextSize = 17,
		Font = Enum.Font.Gotham,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		Parent = parent.content,
	})

	table.insert(allOptionRefs, { label = main, option = option, parent = parent })

	local bg = create("ImageLabel", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.5, 0, 0.5, 0),
		Size = UDim2.new(1, -12, 1, -10),
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = Color3.fromRGB(40, 40, 40),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent = main,
	})

	local inContact = false
	local clicking  = false

	main.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			library.flags[option.flag] = true
			clicking = true
			tween(bg, TWEEN_MED, { ImageColor3 = library.accent })
			option.callback()
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = true
			tween(bg, TWEEN_FAST, { ImageColor3 = Color3.fromRGB(60, 60, 60) })
		end
	end)

	main.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			clicking = false
			tween(bg, TWEEN_MED, {
				ImageColor3 = if inContact then Color3.fromRGB(60, 60, 60) else Color3.fromRGB(40, 40, 40),
			})
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = false
			if not clicking then
				tween(bg, TWEEN_FAST, { ImageColor3 = Color3.fromRGB(40, 40, 40) })
			end
		end
	end)
end

-- Bind ----------------------------------------------------------------
local function createBind(option: any, parent: any)
	local binding = false
	local loop: RBXScriptConnection? = nil
	local text = if string.match(option.key, "Mouse")
		then string.sub(option.key, 1, 5) .. string.sub(option.key, 12, 13)
		else option.key

	local main = create("TextLabel", {
		LayoutOrder = option.position,
		Size = UDim2.new(1, 0, 0, 33),
		BackgroundTransparency = 1,
		Text = " " .. option.text,
		TextSize = 17,
		Font = Enum.Font.Gotham,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = parent.content,
	})

	table.insert(allOptionRefs, { label = main, option = option, parent = parent })

	local bg = create("ImageLabel", {
		Position = UDim2.new(1, -6, 0, 4),
		Size = UDim2.new(0, -measureText(text, 16, Enum.Font.Gotham).X - 16, 1, -10),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = Color3.fromRGB(40, 40, 40),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent = main,
	})

	local bindLabel = create("TextLabel", {
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Text = text,
		TextSize = 16,
		Font = Enum.Font.Gotham,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		Parent = bg,
	})

	local inContact = false

	main.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = true
			if not binding then
				tween(bg, TWEEN_FAST, { ImageColor3 = Color3.fromRGB(60, 60, 60) })
			end
		end
	end)

	main.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			binding = true
			bindLabel.Text = "..."
			tween(bg, TWEEN_MED, { ImageColor3 = library.accent })
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = false
			if not binding then
				tween(bg, TWEEN_FAST, { ImageColor3 = Color3.fromRGB(40, 40, 40) })
			end
		end
	end)

	table.insert(connections, InputService.InputBegan:Connect(function(input)
		if InputService:GetFocusedTextBox() then return end
		if (input.KeyCode.Name == option.key or input.UserInputType.Name == option.key) and not binding then
			if option.hold then
				loop = RunService.Heartbeat:Connect(function()
					if binding then
						option.callback(true)
						if loop then loop:Disconnect(); loop = nil end
					else
						option.callback()
					end
				end)
			else
				option.callback()
			end
		elseif binding then
			local key: any = nil
			pcall(function()
				if not contains(BLACKLISTED_KEYS, input.KeyCode) then
					key = input.KeyCode
				end
			end)
			pcall(function()
				if contains(WHITELISTED_MOUSE, input.UserInputType) and not key then
					key = input.UserInputType
				end
			end)
			key = key or option.key
			option:SetKey(key)
		end
	end))

	table.insert(connections, InputService.InputEnded:Connect(function(input)
		if input.KeyCode.Name == option.key or input.UserInputType.Name == option.key then
			if loop then
				loop:Disconnect()
				loop = nil
				option.callback(true)
			end
		end
	end))

	function option:SetKey(key: any)
		binding = false
		if loop then loop:Disconnect(); loop = nil end
		self.key = if key then (if typeof(key) == "EnumItem" then key.Name else key) else self.key
		library.flags[self.flag] = self.key
		local display = self.key
		if string.match(self.key, "Mouse") then
			display = string.sub(self.key, 1, 5) .. string.sub(self.key, 12, 13)
		end
		bindLabel.Text = display
		tween(bg, TWEEN_MED, {
			ImageColor3 = if inContact then Color3.fromRGB(60, 60, 60) else Color3.fromRGB(40, 40, 40),
		})
		bg.Size = UDim2.new(0, -measureText(display, 15, Enum.Font.Gotham).X - 16, 1, -10)
	end
end

-- Slider --------------------------------------------------------------
local function createSlider(option: any, parent: any)
	local main = create("Frame", {
		LayoutOrder = option.position,
		Size = UDim2.new(1, 0, 0, 50),
		BackgroundTransparency = 1,
		Parent = parent.content,
	})

	table.insert(allOptionRefs, { label = main, option = option, parent = parent })

	local title = create("TextLabel", {
		Position = UDim2.new(0, 0, 0, 4),
		Size = UDim2.new(1, 0, 0, 20),
		BackgroundTransparency = 1,
		Text = " " .. option.text,
		TextSize = 17,
		Font = Enum.Font.Gotham,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = main,
	})

	local slider = create("ImageLabel", {
		Position = UDim2.new(0, 10, 0, 34),
		Size = UDim2.new(1, -20, 0, 5),
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = Color3.fromRGB(30, 30, 30),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent = main,
	})

	local fill = create("ImageLabel", {
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = Color3.fromRGB(60, 60, 60),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent = slider,
	})

	local circle = create("ImageLabel", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new((option.value - option.min) / (option.max - option.min), 0, 0.5, 0),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = Color3.fromRGB(60, 60, 60),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 1,
		Parent = slider,
	})

	local valueRound = create("ImageLabel", {
		Position = UDim2.new(1, -6, 0, 4),
		Size = UDim2.new(0, -60, 0, 18),
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = Color3.fromRGB(40, 40, 40),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent = main,
	})

	local inputValue = create("TextBox", {
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Text = tostring(option.value),
		TextColor3 = Color3.fromRGB(235, 235, 235),
		TextSize = 15,
		TextWrapped = true,
		Font = Enum.Font.Gotham,
		Parent = valueRound,
	}) :: TextBox

	-- initial fill
	if option.min >= 0 then
		fill.Size = UDim2.new((option.value - option.min) / (option.max - option.min), 0, 1, 0)
	else
		fill.Position = UDim2.new((0 - option.min) / (option.max - option.min), 0, 0, 0)
		fill.Size = UDim2.new(option.value / (option.max - option.min), 0, 1, 0)
	end

	local sliding   = false
	local inContact = false

	main.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			tween(fill, TWEEN_MED, { ImageColor3 = library.accent })
			tween(circle, TWEEN_MED, { Size = UDim2.new(3.5, 0, 3.5, 0), ImageColor3 = library.accent })
			sliding = true
			option:SetValue(option.min + ((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X) * (option.max - option.min))
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = true
			if not sliding then
				tween(fill, TWEEN_MED, { ImageColor3 = Color3.fromRGB(100, 100, 100) })
				tween(circle, TWEEN_MED, { Size = UDim2.new(2.8, 0, 2.8, 0), ImageColor3 = Color3.fromRGB(100, 100, 100) })
			end
		end
	end)

	table.insert(connections, InputService.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement and sliding then
			option:SetValue(option.min + ((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X) * (option.max - option.min))
		end
	end))

	main.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			sliding = false
			local c = if inContact then Color3.fromRGB(100, 100, 100) else Color3.fromRGB(60, 60, 60)
			local s = if inContact then UDim2.new(2.8, 0, 2.8, 0) else UDim2.new(0, 0, 0, 0)
			tween(fill, TWEEN_MED, { ImageColor3 = c })
			tween(circle, TWEEN_MED, { Size = s, ImageColor3 = c })
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = false
			inputValue:ReleaseFocus()
			if not sliding then
				tween(fill, TWEEN_MED, { ImageColor3 = Color3.fromRGB(60, 60, 60) })
				tween(circle, TWEEN_MED, { Size = UDim2.new(0, 0, 0, 0), ImageColor3 = Color3.fromRGB(60, 60, 60) })
			end
		end
	end)

	inputValue.FocusLost:Connect(function()
		tween(circle, TWEEN_MED, { Size = UDim2.new(0, 0, 0, 0), ImageColor3 = Color3.fromRGB(60, 60, 60) })
		option:SetValue(tonumber(inputValue.Text) or option.value)
	end)

	function option:SetValue(value: number)
		value = round(value, self.float)
		value = math.clamp(value, self.min, self.max)
		circle:TweenPosition(UDim2.new((value - self.min) / (self.max - self.min), 0, 0.5, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
		if self.min >= 0 then
			fill:TweenSize(UDim2.new((value - self.min) / (self.max - self.min), 0, 1, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
		else
			fill:TweenPosition(UDim2.new((0 - self.min) / (self.max - self.min), 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
			fill:TweenSize(UDim2.new(value / (self.max - self.min), 0, 1, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
		end
		library.flags[self.flag] = value
		self.value = value
		inputValue.Text = tostring(value)
		self.callback(value)
	end
end

