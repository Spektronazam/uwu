local function createList(option: any, parent: any, holder: any?)
	local valueCount = 0

	local main = create("Frame", {
		LayoutOrder = option.position,
		Size = UDim2.new(1, 0, 0, 52),
		BackgroundTransparency = 1,
		Parent = parent.content,
	})

	table.insert(allOptionRefs, { label = main, option = option, parent = parent })

	local bg = create("ImageLabel", {
		Position = UDim2.new(0, 6, 0, 4),
		Size = UDim2.new(1, -12, 1, -10),
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = Color3.fromRGB(40, 40, 40),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent = main,
	})

	create("TextLabel", {
		Position = UDim2.new(0, 12, 0, 8),
		Size = UDim2.new(1, -24, 0, 14),
		BackgroundTransparency = 1,
		Text = option.text,
		TextSize = 14,
		Font = Enum.Font.GothamBold,
		TextColor3 = Color3.fromRGB(140, 140, 140),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = main,
	})

	local listValue = create("TextLabel", {
		Position = UDim2.new(0, 12, 0, 20),
		Size = UDim2.new(1, -24, 0, 24),
		BackgroundTransparency = 1,
		Text = option.value,
		TextSize = 18,
		Font = Enum.Font.Gotham,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = main,
	})

	create("ImageLabel", {
		Position = UDim2.new(1, -16, 0, 16),
		Size = UDim2.new(-1, 32, 1, -32),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		Rotation = 90,
		BackgroundTransparency = 1,
		Image = ARROW_IMAGE,
		ImageColor3 = Color3.fromRGB(140, 140, 140),
		ScaleType = Enum.ScaleType.Fit,
		Parent = bg,
	})

	option.mainHolder = create("ImageButton", {
		ZIndex = 3,
		Size = UDim2.new(0, WINDOW_WIDTH + 10, 0, 52),
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageTransparency = 1,
		ImageColor3 = Color3.fromRGB(30, 30, 30),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Visible = false,
		Parent = library.base,
	})

	local content = create("ScrollingFrame", {
		ZIndex = 3,
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarImageColor3 = Color3.new(),
		ScrollBarThickness = 0,
		ScrollingDirection = Enum.ScrollingDirection.Y,
		Parent = option.mainHolder,
	}) :: ScrollingFrame

	create("UIPadding", { PaddingTop = UDim.new(0, 6), Parent = content })

	local layout = create("UIListLayout", { Parent = content }) :: UIListLayout

	layout.Changed:Connect(function()
		option.mainHolder.Size = UDim2.new(0, WINDOW_WIDTH + 10, 0, (if valueCount > 4 then 4 * 40 else layout.AbsoluteContentSize.Y) + 12)
		content.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 12)
	end)

	local inContact = false

	bg.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			if library.activePopup then library.activePopup:Close() end
			local pos = main.AbsolutePosition
			option.mainHolder.Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 10)
			option.open = true
			option.mainHolder.Visible = true
			library.activePopup = option
			content.ScrollBarThickness = 6
			tween(option.mainHolder, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				ImageTransparency = 0,
				Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 4),
			})
			task.delay(0.1, function()
				tween(option.mainHolder, TWEEN_SLOW, { Position = UDim2.new(0, pos.X - 5, 0, pos.Y + 1) })
			end)
			for _, label in content:GetChildren() do
				if label:IsA("TextLabel") then
					tween(label, TWEEN_SLOW, { BackgroundTransparency = 0, TextTransparency = 0 })
				end
			end
		elseif input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = true
			if not option.open then
				tween(bg, TWEEN_FAST, { ImageColor3 = Color3.fromRGB(60, 60, 60) })
			end
		end
	end)

	bg.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = false
			if not option.open then
				tween(bg, TWEEN_FAST, { ImageColor3 = Color3.fromRGB(40, 40, 40) })
			end
		end
	end)

	function option:AddValue(value: string)
		valueCount += 1
		local label = create("TextLabel", {
			ZIndex = 3,
			Size = UDim2.new(1, 0, 0, 40),
			BackgroundColor3 = Color3.fromRGB(30, 30, 30),
			BorderSizePixel = 0,
			Text = "    " .. value,
			TextSize = 14,
			TextTransparency = if self.open then 0 else 1,
			Font = Enum.Font.Gotham,
			TextColor3 = Color3.fromRGB(255, 255, 255),
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = content,
		})

		local contact  = false
		local clicking = false

		label.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				clicking = true
				tween(label, TWEEN_MED, { BackgroundColor3 = Color3.fromRGB(10, 10, 10) })
				self:SetValue(value)
			elseif input.UserInputType == Enum.UserInputType.MouseMovement then
				contact = true
				if not clicking then
					tween(label, TWEEN_FAST, { BackgroundColor3 = Color3.fromRGB(20, 20, 20) })
				end
			end
		end)

		label.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				clicking = false
				tween(label, TWEEN_MED, {
					BackgroundColor3 = if contact then Color3.fromRGB(20, 20, 20) else Color3.fromRGB(30, 30, 30),
				})
			elseif input.UserInputType == Enum.UserInputType.MouseMovement then
				contact = false
				if not clicking then
					tween(label, TWEEN_FAST, { BackgroundColor3 = Color3.fromRGB(30, 30, 30) })
				end
			end
		end)
	end

	if not table.find(option.values, option.value) then
		option:AddValue(option.value)
	end
	for _, v in option.values do
		option:AddValue(tostring(v))
	end

	function option:RemoveValue(value: string)
		for _, label in content:GetChildren() do
			if label:IsA("TextLabel") and label.Text == "	" .. value then
				label:Destroy()
				valueCount -= 1
				break
			end
		end
		if self.value == value then self:SetValue("") end
	end

	function option:SetValue(value: string)
		library.flags[self.flag] = tostring(value)
		self.value = tostring(value)
		listValue.Text = self.value
		self.callback(value)
	end

	function option:Close()
		library.activePopup = nil
		self.open = false
		content.ScrollBarThickness = 0
		local pos = main.AbsolutePosition
		tween(bg, TWEEN_MED, { ImageColor3 = if inContact then Color3.fromRGB(60, 60, 60) else Color3.fromRGB(40, 40, 40) })
		tween(self.mainHolder, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			ImageTransparency = 1,
			Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 10),
		})
		for _, label in content:GetChildren() do
			if label:IsA("TextLabel") then
				tween(label, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					BackgroundTransparency = 1, TextTransparency = 1,
				})
			end
		end
		task.delay(0.3, function()
			if not self.open then
				self.mainHolder.Visible = false
			end
		end)
	end

	return option
end

