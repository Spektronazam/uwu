	})

	create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 0, 0, 0),
		Size = UDim2.new(1, -64, 1, 0),
		Text = " " .. option.text,
		Font = Enum.Font.Gotham,
		TextSize = 15,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = main,
	})

	local bindBg = rounded("ImageLabel", {
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, -3, 0.5, 0),
		Size = UDim2.new(0, 54, 0, 20),
		ImageColor3 = Color3.fromRGB(18, 18, 18),
		Parent = main,
	})

	local bindText = create("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Text = "",
		Font = Enum.Font.GothamSemibold,
		TextSize = 12,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		Parent = bindBg,
	})

	option.main = main
	library.flags[option.flag] = option.key

	local binding = false
	local held = false

	local function refreshDisplay()
		local txt = formatBindKey(option.key)
		bindText.Text = txt
		local width = measureText(txt, 12, Enum.Font.GothamSemibold).X + 16
		bindBg.Size = UDim2.new(0, math.max(40, width), 0, 20)
		library.flags[option.flag] = option.key
	end

	local function setBindVisual(active)
		tween(bindBg, TWEEN_FAST, {
			ImageColor3 = active and library.accent or Color3.fromRGB(18, 18, 18),
		})
	end

	option._maid:GiveTask(bindAccentCallback(function(accent)
		if binding and bindBg.Parent then
			bindBg.ImageColor3 = accent
		end
	end))

	function option:SetKey(key, silent)
		if typeof(key) == "EnumItem" then
			key = key.Name
		end

		self.key = tostring(key)
		binding = false
		held = false
		refreshDisplay()
		setBindVisual(false)

		if not silent then
			safeCall(self.text, self.callback, false)
		end
	end

	option._maid:GiveTask(main.MouseButton1Click:Connect(function()
		binding = true
		bindText.Text = "..."
		setBindVisual(true)
	end))

	option._maid:GiveTask(InputService.InputBegan:Connect(function(input, processed)
		if binding then
			local newKey = getBindableInput(input)
			binding = false

			if newKey then
				option.key = newKey
			end

			refreshDisplay()
			setBindVisual(false)
			return
		end

		if processed or InputService:GetFocusedTextBox() then
			return
		end

		if inputMatches(input, option.key) then
			if option.hold then
				held = true
			else
				safeCall(option.text, option.callback)
			end
		end
	end))

	option._maid:GiveTask(RunService.Heartbeat:Connect(function()
		if held then
			safeCall(option.text, option.callback)
		end
	end))

	option._maid:GiveTask(InputService.InputEnded:Connect(function(input)
		if held and inputMatches(input, option.key) then
			held = false
			safeCall(option.text, option.callback, true)
		end
	end))

	refreshDisplay()
end

