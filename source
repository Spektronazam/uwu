		AnchorPoint = Vector2.new(0, 0.5),
		Position = UDim2.new(0, 30, 0.5, 0),
		Size = UDim2.new(1, -36, 1, -8),
		BackgroundTransparency = 1,
		Text = "",
		PlaceholderText = "Search options...",
		PlaceholderColor3 = Color3.fromRGB(80, 80, 80),
		TextColor3 = Color3.fromRGB(220, 220, 220),
		TextSize = 14,
		Font = Enum.Font.Gotham,
		TextXAlignment = Enum.TextXAlignment.Left,
		ClearTextOnFocus = false,
		ZIndex = 11,
		Parent = bar,
	}) :: TextBox
	searchInput = input

	-- Results dropdown
	local results = create("Frame", {
		Position = UDim2.new(0, 0, 1, 4),
		Size = UDim2.new(1, 0, 0, 0),
		BackgroundTransparency = 1,
		ClipsDescendants = true,
		ZIndex = 12,
		Parent = bar,
	}) :: Frame
	searchResults = results

	local resultsBg = create("ImageLabel", {
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Image = ROUND_IMAGE,
		ImageColor3 = Color3.fromRGB(18, 18, 18),
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.04,
		ZIndex = 12,
		Parent = results,
	})

	local resultsLayout = create("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 2),
		Parent = results,
	}) :: UIListLayout

	create("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingLeft = UDim.new(0, 4), PaddingRight = UDim.new(0, 4), Parent = results })

	-- Open search bar on click
	local function openSearch()
		if searchOpen then return end
		searchOpen = true
		tween(bar, TWEEN_SLOW, { Size = UDim2.new(0, WINDOW_WIDTH, 0, 30) })
		tween(icon, TWEEN_MED, { ImageColor3 = library.accent })
		task.delay(0.2, function() input:CaptureFocus() end)
	end

	local function closeSearch()
		if not searchOpen then return end
		searchOpen = false
		input:ReleaseFocus()
		input.Text = ""
		tween(bar, TWEEN_SLOW, { Size = UDim2.new(0, 30, 0, 30) })
		tween(icon, TWEEN_MED, { ImageColor3 = Color3.fromRGB(120, 120, 120) })
		-- Clear results
		for _, c in results:GetChildren() do
			if c:IsA("TextButton") then c:Destroy() end
		end
		tween(results, TWEEN_FAST, { Size = UDim2.new(1, 0, 0, 0) })
	end

	icon.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			if searchOpen then closeSearch() else openSearch() end
		end
	end)

	bg.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			openSearch()
		end
	end)

	input.FocusLost:Connect(function()
		task.delay(0.2, function()
			if not input:IsFocused() then closeSearch() end
		end)
	end)

	-- Smart search recommendations
	input:GetPropertyChangedSignal("Text"):Connect(function()
		-- Clear previous results
		for _, c in results:GetChildren() do
			if c:IsA("TextButton") then c:Destroy() end
		end

		local query = string.lower(input.Text)
		if query == "" then
			tween(results, TWEEN_FAST, { Size = UDim2.new(1, 0, 0, 0) })
			return
		end

		local matched = 0
		local MAX_RESULTS = 6

		for _, ref in allOptionRefs do
			if matched >= MAX_RESULTS then break end
			local optText = string.lower(ref.option.text or "")
			local optFlag = string.lower(ref.option.flag or "")

			-- fuzzy: all chars of query appear in order
			local function fuzzyMatch(source: string): boolean
				local qi = 1
				for si = 1, #source do
					if qi > #query then break end
					if string.sub(source, si, si) == string.sub(query, qi, qi) then
						qi += 1
					end
				end
				return qi > #query
			end

			if string.find(optText, query, 1, true) or string.find(optFlag, query, 1, true) or fuzzyMatch(optText) then
				matched += 1
				local resultBtn = create("TextButton", {
					Size = UDim2.new(1, 0, 0, 26),
					BackgroundColor3 = Color3.fromRGB(26, 26, 26),
					BorderSizePixel = 0,
					Text = "  " .. ref.option.text .. "  [" .. ref.option.type .. "]",
					TextSize = 13,
					Font = Enum.Font.Gotham,
					TextColor3 = Color3.fromRGB(200, 200, 200),
					TextXAlignment = Enum.TextXAlignment.Left,
					ZIndex = 13,
					Parent = results,
				})
				create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = resultBtn })

				resultBtn.InputBegan:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseMovement then
						tween(resultBtn, TWEEN_FAST, { BackgroundColor3 = Color3.fromRGB(35, 35, 35) })
					end
				end)
				resultBtn.InputEnded:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseMovement then
						tween(resultBtn, TWEEN_FAST, { BackgroundColor3 = Color3.fromRGB(26, 26, 26) })
					end
				end)

				resultBtn.MouseButton1Click:Connect(function()
					-- Scroll the matching element into view / highlight
					local lbl = ref.label
					if lbl and lbl:IsA("GuiObject") then
						-- Brief flash highlight
						local origColor = lbl.BackgroundColor3
						tween(lbl, TWEEN_FAST, { BackgroundTransparency = 0, BackgroundColor3 = library.accent })
						task.delay(0.6, function()
							tween(lbl, TWEEN_MED, { BackgroundTransparency = 1, BackgroundColor3 = origColor })
						end)
					end
					closeSearch()
				end)
			end
		end

		local totalH = matched * 28 + 8
		tween(results, TWEEN_FAST, { Size = UDim2.new(1, 0, 0, totalH) })
	end)
end

------------------------------------------------------------------------
-- ENTRANCE / EXIT ANIMATIONS
------------------------------------------------------------------------
-- Slide all windows from center to left & fade in
local function entranceAnimation()
	local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)

	for _, window in library.windows do
		if window.main then
			-- Start from center, invisible
			local targetPos = window.main.Position
			local centerX   = viewport.X / 2 - window.main.AbsoluteSize.X / 2
			window.main.Position = UDim2.new(0, centerX, targetPos.Y.Scale, targetPos.Y.Offset)
			window.main.ImageTransparency = 1

			-- Fade + slide
			tween(window.main, TWEEN_ENTER, {
				Position = targetPos,
				ImageTransparency = 0,
			})
		end
	end

	-- Fade in search bar
	if searchBar then
		searchBar.BackgroundTransparency = 1
		tween(searchBar, TWEEN_ENTER, { BackgroundTransparency = 1 }) -- it's already transp, children fade
	end
end

local function exitAnimation(callback: (() -> ())?)
	local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)

	for _, window in library.windows do
		if window.main then
			-- Reset to original size first (undo user resize)
			local orig = windowOriginals[window]
			if orig then
				tween(window.main, TWEEN_MED, { Size = orig.size })
			end

			-- Then slide to center & fade out
			local centerX = viewport.X / 2 - window.main.AbsoluteSize.X / 2
			task.delay(0.2, function()
				tween(window.main, TWEEN_EXIT, {
					Position = UDim2.new(0, centerX, window.main.Position.Y.Scale, window.main.Position.Y.Offset),
					ImageTransparency = 1,
				})
			end)
		end
	end

	task.delay(0.75, function()
		if callback then callback() end
	end)
end

local function reEntranceAnimation()
	local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)

	for _, window in library.windows do
		if window.main then
			local centerX = viewport.X / 2 - window.main.AbsoluteSize.X / 2
			window.main.Position = UDim2.new(0, centerX, window.main.Position.Y.Scale, window.main.Position.Y.Offset)
			window.main.ImageTransparency = 1
			window.main.Visible = true

			local orig = windowOriginals[window]
			local target = if orig then orig.pos else window.main.Position

			tween(window.main, TWEEN_ENTER, {
				Position = target,
				ImageTransparency = 0,
			})
		end
	end
end

------------------------------------------------------------------------
-- library:Init
------------------------------------------------------------------------
function library:Init(): ScreenGui?
	self.base = self.base or create("ScreenGui", {
		ResetOnSpawn = false,
		Name = "uwuware_reborn",
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
	}) :: ScreenGui

	-- Protection
	local ok = false
	if syn and syn.protect_gui then
		syn.protect_gui(self.base)
		ok = true
	end
	if not ok then
		pcall(function()
			if gethui then
				self.base.Parent = gethui()
				ok = true
			end
		end)
	end
	if not ok then
		pcall(function()
			self.base.Parent = game:GetService("CoreGui")
			ok = true
		end)
	end
	if not ok then
		self.base.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
	end

	-- Loading throbber
	local _, finishThrobber = createThrobber(self.base)

	-- Build windows while throbber spins (give it a minimum display time)
	local buildStart = tick()

	for _, window in self.windows do
		if window.canInit and not window.init then
			window.init = true
			createOptionHolder(window.title, self.base, window)
			loadOptions(window)
			-- Start hidden for entrance animation
			if window.main then
				window.main.ImageTransparency = 1
			end
		end
	end

	-- Search bar
	createSearchBar(self.base)

	-- Cursor
	self.cursor = self.cursor or create("Frame", {
		ZIndex = 100,
		AnchorPoint = Vector2.new(0, 0),
		Size = UDim2.new(0, 5, 0, 5),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		Parent = self.base,
	}) :: Frame
	create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = self.cursor })

	-- Ensure throbber shows at least ~1s
	local elapsed = tick() - buildStart
	if elapsed < 1 then
		task.wait(1 - elapsed)
	end

	-- Finish throbber (slows down, fades out)
	finishThrobber()

	-- Small pause before windows appear
	task.wait(0.15)

	-- Entrance animation: slide from center → left, fade in
	entranceAnimation()

	return self.base
end

------------------------------------------------------------------------
-- library:Close — toggle with undo-resize exit anim
------------------------------------------------------------------------
function library:Close()
	if typeof(self.base) ~= "Instance" then return end

	if self.open then
		-- CLOSING: exit animation (resize back → slide center → fade out)
		self.open = false
		if self.cursor then self.cursor.Visible = false end
		if self.activePopup then self.activePopup:Close() end
		if searchBar then searchBar.Visible = false end

		exitAnimation(function()
			for _, window in self.windows do
				if window.main then window.main.Visible = false end
			end
		end)
	else
		-- OPENING: re-entrance (slide left → fade in)
		self.open = true
		if self.cursor then self.cursor.Visible = true end
		if searchBar then searchBar.Visible = true end

		reEntranceAnimation()
	end
end

------------------------------------------------------------------------
-- library:SetAccent
------------------------------------------------------------------------
function library:SetAccent(color: Color3)
	self.accent = color
end

------------------------------------------------------------------------
-- library:LoadConfig — resets window sizes when a config is loaded
------------------------------------------------------------------------
function library:LoadConfig(flagData: { [string]: Flag })
	for key, value in flagData do
		self.flags[key] = value
	end
	-- Reset all windows to original size with a smooth tween
	for _, window in self.windows do
		if window.main then
			window:ResetSize()
		end
	end
end

------------------------------------------------------------------------
-- Global input handling
------------------------------------------------------------------------

-- Close popups when clicking outside
table.insert(connections, InputService.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
	if not library.activePopup then return end

	local popup = library.activePopup
	local holder = popup.mainHolder
	if not holder then return end

	local pos  = holder.AbsolutePosition
	local size = holder.AbsoluteSize
	local mx, my = input.Position.X, input.Position.Y

	if mx < pos.X or my < pos.Y or mx > pos.X + size.X or my > pos.Y + size.Y then
		popup:Close()
	end
end))

-- Cursor tracking + drag
table.insert(connections, InputService.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement and library.cursor then
		local mouse = InputService:GetMouseLocation() + Vector2.new(0, -36)
		library.cursor.Position = UDim2.new(0, mouse.X - 2, 0, mouse.Y - 2)
	end
	if input == dragInput and dragging then
		updateDrag(input)
	end
end))

return library
