------------------------------------------------------------------------
-- Utility helpers
------------------------------------------------------------------------
local function round(num: number, bracket: number?): number
	local b = bracket or 1
	local a = math.floor(num / b + math.sign(num) * 0.5) * b
	if a < 0 then a += b end
	return a
end

local function contains<T>(list: { T }, value: T): boolean
	for _, v in list do
		if v == value then return true end
	end
	return false
end

local function tween(obj: Instance, info: TweenInfo, goals: { [string]: any })
	TweenService:Create(obj, info, goals):Play()
end

local function tweenWait(obj: Instance, info: TweenInfo, goals: { [string]: any })
	local t = TweenService:Create(obj, info, goals)
	t:Play()
	t.Completed:Wait()
end

local function measureText(text: string, size: number, font: Enum.Font): Vector2
	return TextService:GetTextSize(text, size, font, Vector2.new(1e9, 1e9))
end

------------------------------------------------------------------------
-- Instance factory
------------------------------------------------------------------------
local function create<T>(class: string, props: { [string]: any }?): T
	local inst = Instance.new(class)
	if props then
		for k, v in props do
			(inst :: any)[k] = v
		end
	end
	return inst :: any
end

