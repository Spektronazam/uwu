		Visible = option.min < 0 and option.max > 0,
		Parent = barBg,
	})

	local fill = rounded("ImageLabel", {
		Position = UDim2.new(0, 0, 0, 0),
		Size = UDim2.new(0, 0, 1, 0),
		SliceScale = 0.02,
		ImageColor3 = library.accent,
		Parent = barBg,
	})

	local knob = create("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0, 0, 0.5, 0),
		Size = UDim2.new(0, 10, 0, 10),
		BorderSizePixel = 0,
		BackgroundColor3 = library.accent,
		Parent = barBg,
	})
	create("UICorner", {
		CornerRadius = UDim.new(1, 0),
		Parent = knob,
	})

	option.main = main
	option._maid:GiveTask(bindAccentProperty(fill, "ImageColor3"))
	option._maid:GiveTask(bindAccentProperty(knob, "BackgroundColor3"))

	local dragging = false

	local function refreshVisuals(instant)
		local alpha = sliderAlpha(option.min, option.max, option.value)
		local left, width, zero = sliderFill(option.min, option.max, option.value)

		if zero then
			zeroLine.Visible = true
			zeroLine.Position = UDim2.fromScale(zero, 0.5)
		else
			zeroLine.Visible = false
		end

		local knobPos = UDim2.fromScale(alpha, 0.5)
		local fillPos = UDim2.fromScale(left, 0)
		local fillSize = UDim2.fromScale(width, 1)

		if instant then
			knob.Position = knobPos
			fill.Position = fillPos
			fill.Size = fillSize
		else
			tween(knob, TWEEN_FAST, { Position = knobPos })
			tween(fill, TWEEN_FAST, { Position = fillPos, Size = fillSize })
		end

		valueLabel.Text = tostring(option.value)
	end

	local function setFromMouse(x)
		local alpha = math.clamp((x - barBg.AbsolutePosition.X) / barBg.AbsoluteSize.X, 0, 1)
		local raw = option.min + ((option.max - option.min) * alpha)
		option:SetValue(raw)
	end

	function option:SetValue(value, silent)
		value = tonumber(value) or self.value
		value = roundTo(value, self.float)
		value = math.clamp(value, self.min, self.max)

		self.value = value
		library.flags[self.flag] = value
		refreshVisuals(false)

		if not silent then
			safeCall(self.text, self.callback, value)
		end
	end

	library.flags[option.flag] = option.value
	refreshVisuals(true)

	option._maid:GiveTask(barBg.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			setFromMouse(input.Position.X)
		end
	end))

	option._maid:GiveTask(knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			setFromMouse(input.Position.X)
		end
	end))

	option._maid:GiveTask(InputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			setFromMouse(input.Position.X)
		end
	end))

	option._maid:GiveTask(InputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end))

	if option.fireInit then
		task.defer(function()
			safeCall(option.text, option.callback, option.value)
		end)
	end
end

