-- library:CreateWindow
------------------------------------------------------------------------
function library:CreateWindow(windowTitle: string): any
	local window: any = {
		title   = tostring(windowTitle),
		options = {},
		open    = true,
		canInit = true,
		init    = false,
		position = #self.windows,
