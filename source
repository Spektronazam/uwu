	local function makeActionBtn(yPos: number, label: string): (ImageLabel, TextLabel)
		local btn = create("ImageLabel", {
			ZIndex = 3,
			Position = UDim2.new(1, -8, 0, yPos),
			Size = UDim2.new(0, -80, 0, 18),
			BackgroundTransparency = 1,
			Image = ROUND_IMAGE,
			ImageTransparency = 1,
			ImageColor3 = Color3.fromRGB(20, 20, 20),
			ScaleType = Enum.ScaleType.Slice,
			SliceCenter = Rect.new(100, 100, 100, 100),
			SliceScale = 0.02,
			Parent = option.mainHolder,
		})
		local txt = create("TextLabel", {
			ZIndex = 3,
			Size = UDim2.new(1, 0, 1, 0),
			BackgroundTransparency = 1,
			Text = label,
			TextTransparency = 1,
			Font = Enum.Font.Code,
			TextSize = 15,
			TextColor3 = Color3.fromRGB(255, 255, 255),
			Parent = btn,
		})
		btn.InputBegan:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseMovement and not dragging then
				tween(btn, TWEEN_MED, { ImageColor3 = Color3.fromRGB(10, 10, 10) })
			end
		end)
		btn.InputEnded:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseMovement and not dragging then
				tween(btn, TWEEN_MED, { ImageColor3 = Color3.fromRGB(20, 20, 20) })
			end
		end)
		return btn, txt
	end

