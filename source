------------------------------------------------------------------------
-- LOADING THROBBER
------------------------------------------------------------------------
local function createThrobber(parent: ScreenGui): (Frame, () -> ())
	local holder = create("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.5, 0, 0.5, 0),
		Size = UDim2.new(0, 50, 0, 50),
		BackgroundTransparency = 1,
		Parent = parent,
	}) :: Frame

	-- 8 dots in a circle
	local dots: { Frame } = {}
	for i = 0, 7 do
		local angle = math.rad(i * 45)
		local dot = create("Frame", {
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(0.5 + math.cos(angle) * 0.4, 0, 0.5 + math.sin(angle) * 0.4, 0),
			Size = UDim2.new(0, 6, 0, 6),
			BackgroundColor3 = library.accent,
			BackgroundTransparency = i / 8,
			Parent = holder,
		}) :: Frame
		create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = dot })
		table.insert(dots, dot)
	end

	-- Spin animation
	local spinning    = true
	local speed       = 1
	local accumulated = 0

	local spinConn = RunService.Heartbeat:Connect(function(dt)
		if not spinning then return end
		accumulated += dt * speed * 360 -- degrees per second
		holder.Rotation = accumulated % 360
	end)

	-- Cleanup function: slow down → fade out → destroy
	local function finish()
		-- Slow down over 0.6s
		local slowTween = TweenService:Create(
			create("NumberValue", { Value = 1, Parent = holder }),
			TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ Value = 0 }
		)
		-- We'll drive speed from a heartbeat that reads the holder's child value
		local valObj = holder:FindFirstChildOfClass("NumberValue")
		local driveSlow: RBXScriptConnection? = nil
		if valObj then
			driveSlow = RunService.Heartbeat:Connect(function()
				speed = valObj.Value
			end)
		end
		slowTween:Play()
		slowTween.Completed:Wait()
		if driveSlow then driveSlow:Disconnect() end

		-- Fade out dots
		for _, dot in dots do
			tween(dot, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { BackgroundTransparency = 1 })
		end
		task.wait(0.4)
		spinning = false
		spinConn:Disconnect()
		holder:Destroy()
	end

	-- Fade IN the throbber
	for _, dot in dots do
		dot.BackgroundTransparency = 1
	end
	for i, dot in dots do
		tween(dot, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = (i - 1) / 8,
		})
	end

	return holder, finish
end

