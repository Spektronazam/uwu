	maid:GiveTask(bindAccentProperty(accentLine, "BackgroundColor3"))
	maid:GiveTask(searchBar)

	tween(searchBar, TWEEN_ENTER, {
		Position = UDim2.new(0, 20, 0, 22),
	})

	maid:GiveTask(searchInput:GetPropertyChangedSignal("Text"):Connect(function()
		local text = searchInput.Text

		if #text > 0 then
			tween(accentLine, TWEEN_FAST, { Size = UDim2.new(1, -12, 0, 2) })
		else
			tween(accentLine, TWEEN_FAST, { Size = UDim2.new(0, 0, 0, 2) })
		end

		library:SearchFor(text)
	end))

	maid:GiveTask(InputService.InputBegan:Connect(function(input, processed)
		if processed then
			return
		end

		local ctrlDown = InputService:IsKeyDown(Enum.KeyCode.LeftControl) or InputService:IsKeyDown(Enum.KeyCode.RightControl)
		if ctrlDown and input.KeyCode == Enum.KeyCode.F and searchInput then
			searchInput:CaptureFocus()
		end
	end))
end

destroyHolderRecursive = function(holder)
	for _, option in ipairs(holder.options) do
		if option._isHolder then
			destroyHolderRecursive(option)
		else
			if option._maid then
				option._maid:Cleanup()
			end
			option.main = nil
		end
	end

	if holder._maid then
		holder._maid:Cleanup()
	end

	holder.main = nil
	holder.content = nil
	holder.layout = nil
	holder._arrow = nil
	holder._headerBg = nil
	holder._titleLabel = nil
end

function library:Init()
	if self.base then
		return self.base
	end

	self._rootMaid = newMaid()

	local gui = create("ScreenGui", {
		Name = "uwuware reborn v2",
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		DisplayOrder = 999999,
		IgnoreGuiInset = true,
	})

	pcall(function()
		if syn and syn.protect_gui then
			syn.protect_gui(gui)
		end
	end)

	gui.Parent = getGuiParent()
	self.base = gui
	self._rootMaid:GiveTask(gui)

	createSearchBar(gui)
	playLoader(gui)

	for _, window in ipairs(self.windows) do
		window:_Mount(gui)

		if window.main and window._targetPosition then
			window.main.Position = UDim2.new(0, -window.main.AbsoluteSize.X - 40, 0, window._targetPosition.Y.Offset)
			window.main.ImageTransparency = 1

			tween(window.main, TWEEN_ENTER, {
				Position = window._targetPosition,
				ImageTransparency = 0,
			})
		end
	end

	self.open = true
	return gui
end

function library:Close()
	if not self.base then
		return
	end

	local gui = self.base
	self.open = false

	if searchBar then
		tween(searchBar, TWEEN_EXIT, {
			Position = UDim2.new(0, 20, 0, -40),
			ImageTransparency = 1,
		})
	end

	for _, window in ipairs(self.windows) do
		if window.main then
			tween(window.main, TWEEN_EXIT, {
				Position = UDim2.new(0, -window.main.AbsoluteSize.X - 60, 0, window.main.Position.Y.Offset),
				ImageTransparency = 1,
			})
		end
	end

	task.delay(0.35, function()
		for _, window in ipairs(self.windows) do
			destroyHolderRecursive(window)
		end

		if self._rootMaid then
			self._rootMaid:Cleanup()
			self._rootMaid = nil
		end

		if gui and gui.Parent then
			gui:Destroy()
		end

		self.base = nil
		searchBar = nil
		searchInput = nil
		currentSearch = ""
		accentBindings = {}
		windowOriginals = {}
	end)
end

return library
