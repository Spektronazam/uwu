		Image = ARROW_IMAGE,
		ImageColor3 = Color3.fromRGB(70, 70, 70),
		Rotation = option.open and 90 or 180,
		Parent = button,
	})

	local dropdown = create("Frame", {
		Position = UDim2.new(0, 0, 0, 32),
		Size = UDim2.new(1, 0, 0, 0),
		BackgroundTransparency = 1,
		ClipsDescendants = true,
		Visible = option.open,
		Parent = main,
	})

	rounded("ImageLabel", {
		Size = UDim2.new(1, 0, 1, 0),
		ImageColor3 = Color3.fromRGB(16, 16, 16),
		Parent = dropdown,
	})

	local itemsFrame = create("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = dropdown,
	})

	create("UIPadding", {
		PaddingTop = UDim.new(0, 4),
		PaddingBottom = UDim.new(0, 4),
		PaddingLeft = UDim.new(0, 4),
		PaddingRight = UDim.new(0, 4),
		Parent = itemsFrame,
	})

	local layout = create("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 2),
		Parent = itemsFrame,
	})

	option.main = main
	library.flags[option.flag] = option.value

	local function getDropdownHeight()
		return layout.AbsoluteContentSize.Y + 8
	end

	local function refreshHeight(instant)
		local height = option.open and getDropdownHeight() or 0
		dropdown.Visible = option.open

		local targetMain = UDim2.new(1, 0, 0, baseHeight + (option.open and (height + 4) or 0))
		local targetDrop = UDim2.new(1, 0, 0, height)
		local targetRot = option.open and 90 or 180

		if instant then
			dropdown.Size = targetDrop
			main.Size = targetMain
			arrow.Rotation = targetRot
		else
			tween(dropdown, TWEEN_FAST, { Size = targetDrop })
			tween(main, TWEEN_FAST, { Size = targetMain })
			tween(arrow, TWEEN_FAST, { Rotation = targetRot })
		end

		refreshHolderChain(parent, true)
	end

	local function rebuildItems()
		for _, child in ipairs(itemsFrame:GetChildren()) do
			if child:IsA("TextButton") then
				child:Destroy()
			end
		end

		for i, value in ipairs(option.values) do
			local textValue = tostring(value)

			local item = create("TextButton", {
				LayoutOrder = i,
				Size = UDim2.new(1, 0, 0, 22),
				BackgroundTransparency = 1,
				Text = textValue,
				Font = Enum.Font.Gotham,
				TextSize = 13,
				TextColor3 = textValue == option.value and library.accent or Color3.fromRGB(235, 235, 235),
				AutoButtonColor = false,
				Parent = itemsFrame,
			})

			option._maid:GiveTask(bindAccentCallback(function(accent)
				if item.Parent then
					if textValue == option.value then
						item.TextColor3 = accent
					else
						item.TextColor3 = Color3.fromRGB(235, 235, 235)
					end
				end
			end))

			option._maid:GiveTask(item.MouseButton1Click:Connect(function()
				option:SetValue(textValue)
				option:Close()
			end))
		end

		refreshHeight(true)
	end

	function option:SetValue(value, silent)
		value = tostring(value)

		if not contains(option.values, value) then
			table.insert(option.values, value)
		end

		self.value = value
		valueLabel.Text = value
		library.flags[self.flag] = value
		rebuildItems()

		if not silent then
			safeCall(self.text, self.callback, value)
		end
	end

	function option:AddValue(value)
		value = tostring(value)
		if not contains(self.values, value) then
			table.insert(self.values, value)
			rebuildItems()
		end
	end

	function option:RemoveValue(value)
		value = tostring(value)

		for i, v in ipairs(self.values) do
			if tostring(v) == value then
				table.remove(self.values, i)
				break
			end
		end

		if self.value == value then
			self.value = tostring(self.values[1] or "")
			library.flags[self.flag] = self.value
		end

		valueLabel.Text = self.value
		rebuildItems()
	end

	function option:Close()
		option.open = false
		refreshHeight(false)
	end

	valueLabel.Text = option.value
	rebuildItems()
	refreshHeight(true)

	option._maid:GiveTask(button.MouseButton1Click:Connect(function()
		option.open = not option.open
		refreshHeight(false)
	end))

	if option.fireInit then
		task.defer(function()
			safeCall(option.text, option.callback, option.value)
		end)
	end
end

