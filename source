		focused = true
		tween(outline, TWEEN_MED, { ImageColor3 = library.accent })
	end)

	inputValue.FocusLost:Connect(function(enter)
		focused = false
		tween(outline, TWEEN_MED, { ImageColor3 = Color3.fromRGB(60, 60, 60) })
		option:SetValue(inputValue.Text, enter)
	end)

	function option:SetValue(value: string, enter: boolean?)
		library.flags[self.flag] = tostring(value)
		self.value = tostring(value)
		inputValue.Text = self.value
		self.callback(value, enter)
	end
end

