	})

	local accentLine = create("Frame", {
		AnchorPoint = Vector2.new(0, 1),
		Position = UDim2.new(0, 6, 1, -2),
		Size = UDim2.new(0, 0, 0, 2),
		BorderSizePixel = 0,
		BackgroundColor3 = library.accent,
		Parent = searchBar,
