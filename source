local function newMaid()
	local self = {
		_tasks = {},
	}

	function self:GiveTask(task)
		table.insert(self._tasks, task)
		return task
	end

	function self:Cleanup()
		for i = #self._tasks, 1, -1 do
			local task = self._tasks[i]
			local kind = typeof(task)

			if kind == "RBXScriptConnection" then
				task:Disconnect()
			elseif kind == "Instance" then
				if task.Parent ~= nil then
					task:Destroy()
				end
			elseif kind == "function" then
				task()
			end

			self._tasks[i] = nil
		end
	end

	return self
end

local function create(className, props)
	local instance = Instance.new(className)

	if props then
		for k, v in pairs(props) do
			instance[k] = v
		end
	end

	return instance
end

local function rounded(className, props)
	props = props or {}
	if props.BackgroundTransparency == nil then
		props.BackgroundTransparency = 1
	end
	props.Image = props.Image or ROUND_IMAGE
	props.ScaleType = props.ScaleType or Enum.ScaleType.Slice
	props.SliceCenter = props.SliceCenter or Rect.new(100, 100, 100, 100)
	props.SliceScale = props.SliceScale or 0.03
	return create(className, props)
end

local function tween(obj, info, goals)
	local t = TweenService:Create(obj, info, goals)
	t:Play()
	return t
end

local function measureText(text, size, font)
	return TextService:GetTextSize(text, size, font, Vector2.new(10000, 10000))
end

local function contains(list, value)
	for _, v in ipairs(list) do
		if v == value then
			return true
		end
	end
	return false
end

local function roundTo(value, step)
	step = step or 1
	if step == 0 then
		return value
	end

	local scaled = value / step
	if scaled >= 0 then
		return math.floor(scaled + 0.5) * step
	else
		return math.ceil(scaled - 0.5) * step
	end
end

local function safeCall(name, callback, ...)
	local packed = table.pack(...)
	task.spawn(function()
		local ok, err = pcall(function()
			callback(unpackFn(packed, 1, packed.n))
		end)

		if not ok then
			warn(("[uwuware] %s callback error: %s"):format(tostring(name), tostring(err)))
		end
	end)
end

local function getGuiParent()
	local ok, hui = pcall(function()
		if gethui then
			return gethui()
		end
	end)

	if ok and hui then
		return hui
	end

	return CoreGui
end

local function sanitizeFlag(text)
	local s = string.lower(tostring(text))
	s = s:gsub("%s+", "_")
	s = s:gsub("[^%w_]", "")
	if #s == 0 then
		s = "flag_" .. tostring(math.random(1000, 9999))
	end
	return s
end

local function bindAccentProperty(instance, property, transform)
	local entry = {
		type = "property",
		instance = instance,
		property = property,
		transform = transform,
		dead = false,
	}

	table.insert(accentBindings, entry)

	if transform then
		instance[property] = transform(library.accent)
	else
		instance[property] = library.accent
	end

	return function()
		entry.dead = true
	end
end

local function bindAccentCallback(callback)
	local entry = {
		type = "callback",
		callback = callback,
		dead = false,
	}

	table.insert(accentBindings, entry)
	callback(library.accent)

	return function()
		entry.dead = true
	end
end

local function warnDuplicateFlag(flag)
	if flag ~= nil and library.flags[flag] ~= nil then
		warn(("[uwuware] duplicate flag '%s' detected; values may collide"):format(tostring(flag)))
	end
end

local function inputMatches(input, key)
	return input.KeyCode.Name == key or input.UserInputType.Name == key
end

local function getBindableInput(input)
	if input.KeyCode ~= Enum.KeyCode.Unknown and not BLACKLISTED_KEYS[input.KeyCode] then
		return input.KeyCode.Name
	end

	if WHITELISTED_MOUSE[input.UserInputType] then
		return input.UserInputType.Name
	end

	return nil
end

local function formatBindKey(key)
	key = tostring(key)
	return MOUSE_ALIASES[key] or key
end

local function sliderAlpha(min, max, value)
	if max <= min then
		return 0
	end
	return math.clamp((value - min) / (max - min), 0, 1)
end

local function sliderFill(min, max, value)
	local a = sliderAlpha(min, max, value)

	if min < 0 and max > 0 then
		local zero = sliderAlpha(min, max, 0)
		local left = math.min(a, zero)
		local width = math.abs(a - zero)
		return left, width, zero
	end

	return 0, a, nil
end

local function colorToHex(color)
	local r = math.clamp(math.floor(color.R * 255 + 0.5), 0, 255)
	local g = math.clamp(math.floor(color.G * 255 + 0.5), 0, 255)
	local b = math.clamp(math.floor(color.B * 255 + 0.5), 0, 255)
	return string.format("#%02X%02X%02X", r, g, b)
end

